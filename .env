# =============================================================================
# EDR Platform — Environment Configuration
# =============================================================================

# Connection Manager Host Ports
CM_GRPC_PORT=47051
CM_HTTP_PORT=30082

# Dashboard / Web UI
DASHBOARD_PORT=30088

# Shared Infrastructure Host Ports
# Using 31xxx range to avoid Windows Hyper-V reserved port conflicts 
# (Hyper-V often reserves chunks of ports between 1024-10000)
POSTGRES_PORT=31432
REDIS_PORT=31379
ZOOKEEPER_PORT=31181

# Kafka Host Ports
# Internal remains 9092 for docker-to-docker, External (Host) moved to 31292
KAFKA_EXTERNAL_PORT=31292
