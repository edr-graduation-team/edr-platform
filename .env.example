# =============================================================================
# EDR Platform — environment template
#
# Copy this file to `.env` (which is gitignored) and fill in REAL values.
# `docker compose` reads `.env` automatically; `go run`/`npm run` loaders
# read it via your shell or via tools like `direnv` / `dotenv-cli`.
#
# NEVER commit a populated `.env`. NEVER paste real secrets into examples.
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL — used by all back-end services
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_USER=edr
POSTGRES_DB=edr
# Generate a strong value: `openssl rand -base64 32`
POSTGRES_PASSWORD=change-me-please
POSTGRES_PORT=31432
DATABASE_PASSWORD=${POSTGRES_PASSWORD}

# ─────────────────────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────────────────────
REDIS_PORT=31379
# Empty = no auth (only acceptable on a private network). Set a value in prod.
REDIS_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# Kafka
# ─────────────────────────────────────────────────────────────────────────────
ZOOKEEPER_PORT=31181
KAFKA_EXTERNAL_PORT=31292

# ─────────────────────────────────────────────────────────────────────────────
# Initial admin account (used only the first time the DB is seeded)
# ─────────────────────────────────────────────────────────────────────────────
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=admin@example.com
# If left blank the server generates a random password and prints it ONCE
# at startup. Capture it from the logs and change it on first login.
INITIAL_ADMIN_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# JWT (Sigma engine reads JWT_SECRET; Connection Manager uses RSA key files)
# ─────────────────────────────────────────────────────────────────────────────
# `openssl rand -base64 64`
JWT_SECRET=change-me-please

# ─────────────────────────────────────────────────────────────────────────────
# SMTP — outbound email for MFA verification codes
# ─────────────────────────────────────────────────────────────────────────────
SMTP_ENABLED=false
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USE_TLS=true
SMTP_START_TLS=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM="EDR Platform <no-reply@example.com>"
